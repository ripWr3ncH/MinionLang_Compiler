Terminals unused in grammar

   COMMENT_SINGLE
   COMMENT_MULTI


Grammar

    0 $accept: program $end

    1 program: global_declarations

    2 global_declarations: global_declaration
    3                    | global_declarations global_declaration

    4 global_declaration: preprocessor_directive
    5                   | function_definition
    6                   | declaration SEMICOLON
    7                   | SEMICOLON
    8                   | error SEMICOLON

    9 preprocessor_directive: INCLUDE HEADER_FILE
   10                       | DEFINE IDENTIFIER INTEGER_LITERAL
   11                       | DEFINE IDENTIFIER FLOAT_LITERAL
   12                       | DEFINE IDENTIFIER

   13 function_prologue: type_specifier IDENTIFIER

   14 main_prologue: type_specifier MAIN

   15 function_definition: main_prologue LPAREN RPAREN function_body
   16                    | main_prologue LPAREN parameter_list RPAREN function_body
   17                    | function_prologue LPAREN RPAREN function_body
   18                    | function_prologue LPAREN parameter_list RPAREN function_body
   19                    | function_prologue LPAREN RPAREN RETURN_TYPE_IND type_specifier function_body
   20                    | function_prologue LPAREN parameter_list RPAREN RETURN_TYPE_IND type_specifier function_body

   21 parameter_list: parameter
   22               | parameter_list COMMA parameter

   23 parameter: type_specifier IDENTIFIER
   24          | type_specifier IDENTIFIER LBRACKET RBRACKET

   25 type_specifier: TYPE_INT
   26               | TYPE_FLOAT
   27               | TYPE_DOUBLE
   28               | TYPE_LONG_INT
   29               | TYPE_CHAR
   30               | TYPE_BOOL
   31               | TYPE_VOID

   32 declaration: type_specifier declarator_list

   33 declarator_list: declarator
   34                | declarator_list COMMA declarator

   35 declarator: IDENTIFIER
   36           | IDENTIFIER OP_ASSIGN expression
   37           | IDENTIFIER LBRACKET INTEGER_LITERAL RBRACKET
   38           | IDENTIFIER LBRACKET INTEGER_LITERAL RBRACKET OP_ASSIGN LBRACE initializer_list RBRACE
   39           | IDENTIFIER LBRACKET RBRACKET OP_ASSIGN LBRACE initializer_list RBRACE

   40 initializer_list: expression
   41                 | initializer_list COMMA expression

   42 function_body: LBRACE RBRACE
   43              | LBRACE statement_list RBRACE

   44 block_start: /* empty */

   45 scoped_compound_statement: LBRACE block_start RBRACE
   46                          | LBRACE block_start statement_list RBRACE

   47 statement_list: statement
   48               | statement_list statement

   49 statement: declaration SEMICOLON
   50          | expression_statement
   51          | scoped_compound_statement
   52          | selection_statement
   53          | iteration_statement
   54          | jump_statement
   55          | io_statement
   56          | SEMICOLON
   57          | error SEMICOLON

   58 expression_statement: expression SEMICOLON

   59 selection_statement: IF LPAREN expression RPAREN statement
   60                    | IF LPAREN expression RPAREN statement ELSE statement
   61                    | IF LPAREN expression RPAREN statement else_if_chain
   62                    | IF LPAREN expression RPAREN statement else_if_chain ELSE statement
   63                    | SWITCH LPAREN expression RPAREN LBRACE case_list RBRACE

   64 else_if_chain: ELSE_IF LPAREN expression RPAREN statement
   65              | else_if_chain ELSE_IF LPAREN expression RPAREN statement

   66 case_list: case_statement
   67          | case_list case_statement

   68 case_statement: CASE expression COLON statement_list
   69               | CASE expression COLON
   70               | DEFAULT COLON statement_list
   71               | DEFAULT COLON

   72 iteration_statement: WHILE LPAREN expression RPAREN statement
   73                    | DO scoped_compound_statement WHILE LPAREN expression RPAREN SEMICOLON
   74                    | FOR LPAREN for_init COLON expression COLON for_update RPAREN statement
   75                    | FOR LPAREN for_init COLON COLON for_update RPAREN statement
   76                    | FOR LPAREN COLON expression COLON RPAREN statement

   77 for_init: declaration
   78         | expression

   79 for_update: expression
   80           | /* empty */

   81 jump_statement: RETURN SEMICOLON
   82               | RETURN expression SEMICOLON
   83               | BREAK SEMICOLON
   84               | CONTINUE SEMICOLON

   85 io_statement: PRINT LPAREN argument_list RPAREN SEMICOLON
   86             | SCAN LPAREN argument_list RPAREN SEMICOLON

   87 expression: assignment_expression

   88 assignment_expression: logical_or_expression
   89                      | assignment_target OP_ASSIGN assignment_expression

   90 assignment_target: IDENTIFIER
   91                  | IDENTIFIER LBRACKET expression RBRACKET

   92 logical_or_expression: logical_and_expression
   93                      | logical_or_expression OP_OR logical_and_expression

   94 logical_and_expression: logical_xor_expression
   95                       | logical_and_expression OP_AND logical_xor_expression

   96 logical_xor_expression: equality_expression
   97                       | logical_xor_expression OP_XOR equality_expression

   98 equality_expression: relational_expression
   99                    | equality_expression OP_EQ relational_expression
  100                    | equality_expression OP_NE relational_expression

  101 relational_expression: additive_expression
  102                      | relational_expression OP_LT additive_expression
  103                      | relational_expression OP_GT additive_expression
  104                      | relational_expression OP_LE additive_expression
  105                      | relational_expression OP_GE additive_expression

  106 additive_expression: multiplicative_expression
  107                    | additive_expression OP_ADD multiplicative_expression
  108                    | additive_expression OP_SUB multiplicative_expression

  109 multiplicative_expression: unary_expression
  110                          | multiplicative_expression OP_MUL unary_expression
  111                          | multiplicative_expression OP_DIV unary_expression
  112                          | multiplicative_expression OP_MOD unary_expression

  113 unary_expression: postfix_expression
  114                 | OP_NOT unary_expression
  115                 | OP_SUB unary_expression

  116 postfix_expression: primary_expression
  117                   | IDENTIFIER LBRACKET expression RBRACKET
  118                   | function_call

  119 primary_expression: IDENTIFIER
  120                   | INTEGER_LITERAL
  121                   | FLOAT_LITERAL
  122                   | STRING_LITERAL
  123                   | CHAR_LITERAL
  124                   | LPAREN expression RPAREN

  125 function_call: IDENTIFIER LPAREN call_arguments_opt RPAREN
  126              | math_function_call

  127 call_arguments_opt: /* empty */
  128                   | call_argument_list

  129 call_argument_list: assignment_expression
  130                   | call_argument_list COMMA assignment_expression

  131 math_function_call: FUNC_POWER LPAREN expression COMMA expression RPAREN
  132                   | FUNC_SQRT LPAREN expression RPAREN
  133                   | FUNC_FLOOR LPAREN expression RPAREN
  134                   | FUNC_CEIL LPAREN expression RPAREN
  135                   | FUNC_ABS LPAREN expression RPAREN
  136                   | FUNC_LOG LPAREN expression RPAREN
  137                   | FUNC_SIN LPAREN expression RPAREN
  138                   | FUNC_COS LPAREN expression RPAREN
  139                   | FUNC_TAN LPAREN expression RPAREN
  140                   | FUNC_ASIN LPAREN expression RPAREN
  141                   | FUNC_ACOS LPAREN expression RPAREN
  142                   | FUNC_ATAN LPAREN expression RPAREN
  143                   | FUNC_PRIME LPAREN expression RPAREN

  144 argument_list: assignment_expression
  145              | argument_list COMMA assignment_expression


